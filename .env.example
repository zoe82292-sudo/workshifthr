# App
PUBLIC_APP_URL=https://shiftworkshr.com
ALLOWED_ORIGINS=https://shiftworkshr.com,https://www.shiftworkshr.com

# Persistent storage (required in production — Render disk mount path)
DATA_DIR=/var/data/shiftworkshr

# Upload limit (bytes). Default 25 MB.
MAX_UPLOAD_BYTES=26214400

# Auth
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRE_HOURS=24
AUTH_AUTO_PROVISION=true
AUTH_USERS=[{"organization":"Demo Org","password":"YourSharedPassword123!","emails":["demo@shiftworkshr.com"],"allow_domain":"yourcompany.com"}]

# Analysis history (limit applies per signed-in user account)
ANALYSIS_HISTORY_MAX_PER_ORG=25

# Stripe — create products/prices at https://dashboard.stripe.com
# Webhook URL: https://shiftworkshr.com/api/billing/webhook
# Events: checkout.session.completed, invoice.paid, customer.subscription.updated, customer.subscription.deleted
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_CYCLE=price_...
STRIPE_PRICE_ANNUAL=price_...
STRIPE_PRICE_MONTHLY=price_...

# Credential email after checkout (choose one)
# Resend — https://resend.com (recommended)
RESEND_API_KEY=re_...
SMTP_FROM=ShiftWorksHR <hello@shiftworkshr.com>
SUPPORT_EMAIL=hello@shiftworkshr.com

# Or SMTP — Namecheap Private Email (if hello@shiftworkshr.com is on Namecheap)
# SMTP_HOST=mail.privateemail.com
# SMTP_PORT=587
# SMTP_USER=hello@shiftworkshr.com
# SMTP_PASSWORD=your-mailbox-password
# SMTP_FROM=ShiftWorksHR <hello@shiftworkshr.com>
# SMTP_USE_TLS=true

# Or SMTP (Google Workspace, SendGrid, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=hello@shiftworkshr.com
# SMTP_PASSWORD=app-password-here
# SMTP_FROM=ShiftWorksHR <hello@shiftworkshr.com>
# SMTP_USE_TLS=true
