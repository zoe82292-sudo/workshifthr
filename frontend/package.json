{
  "name": "shiftworkshr-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/verify-brand-assets.mjs && tsc -b && vite build",
    "generate:brand": "python ../scripts/generate_brand_assets.py && node scripts/verify-brand-assets.mjs",
    "preview": "vite preview",
    "sync:demo": "python ../scripts/sync_demo_snapshot.py",
